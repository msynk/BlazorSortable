@page "/grid"

<PageTitle>BlazorSortable — Grid</PageTitle>

<div class="demo-section">
    <h1>Grid</h1>
    <p class="demo-lead">
        The component doesn't care about layout — point it at a CSS grid container and
        you get a sortable grid. Drag the squares to rearrange them.
    </p>

    <Sortable @bind-Items="items" TItem="int"
              Class="demo-grid" GhostClass="demo-ghost">
        <ItemTemplate Context="n">
            <div class="grid-square">@n</div>
        </ItemTemplate>
    </Sortable>
</div>

@code {
    private IList<int> items = Enumerable.Range(1, 16).ToList();
}
