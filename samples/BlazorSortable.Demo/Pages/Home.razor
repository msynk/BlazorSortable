@page "/"

<PageTitle>BlazorSortable — Simple list</PageTitle>

<div class="demo-section">
    <h1>Simple list</h1>
    <p class="demo-lead">
        Drag the items to reorder them. Reordering happens live as you drag,
        and the bound list updates with <code>@@bind-Items</code>.
    </p>

    <Sortable Items="items" TItem="string"
              Class="demo-list" ItemClass="demo-item" GhostClass="demo-ghost">
        <ItemTemplate Context="item">
            @item
        </ItemTemplate>
    </Sortable>

    <p class="mt-3"><strong>Order:</strong> @string.Join(", ", items)</p>

    <pre class="mt-3"><code>&lt;Sortable Items="items" TItem="string"&gt;
    &lt;ItemTemplate Context="item"&gt;@@item&lt;/ItemTemplate&gt;
&lt;/Sortable&gt;</code></pre>
</div>

@code {
    private List<string> items = new()
    {
        "Item 1", "Item 2", "Item 3", "Item 4", "Item 5", "Item 6"
    };
}
