@page "/events"

<PageTitle>BlazorSortable — Events</PageTitle>

<div class="demo-section">
    <h1>Events</h1>
    <p class="demo-lead">
        Every drag fires the SortableJS-style lifecycle callbacks. Drag items within
        and between the lists and watch the log.
    </p>

    <div class="demo-columns mb-3">
        <div class="demo-col">
            <BlazorSortable @bind-Items="left" TItem="string" Group="ev"
                      Class="demo-list" ItemClass="demo-item" GhostClass="demo-ghost"
                      OnStart='e => Log("start", e)'
                      OnEnd='e => Log("end", e)'
                      OnAdd='e => Log("add", e)'
                      OnRemove='e => Log("remove", e)'
                      OnUpdate='e => Log("update", e)'>
                <ItemTemplate Context="item">@item</ItemTemplate>
            </BlazorSortable>
        </div>
        <div class="demo-col">
            <BlazorSortable @bind-Items="right" TItem="string" Group="ev"
                      Class="demo-list" ItemClass="demo-item tinted" GhostClass="demo-ghost"
                      OnAdd='e => Log("add", e)'
                      OnRemove='e => Log("remove", e)'
                      OnUpdate='e => Log("update", e)'>
                <ItemTemplate Context="item">@item</ItemTemplate>
            </BlazorSortable>
        </div>
    </div>

    <div class="event-log">
        @if (log.Count == 0)
        {
            <div>No events yet…</div>
        }
        @foreach (var line in log)
        {
            <div>@line</div>
        }
    </div>

    <CodeSnippet>
@@page "/events"

&lt;div class="demo-columns mb-3"&gt;
    &lt;div class="demo-col"&gt;
        &lt;BlazorSortable @@bind-Items="left" TItem="string" Group="ev"
                  Class="demo-list" ItemClass="demo-item" GhostClass="demo-ghost"
                  OnStart='e =&gt; Log("start", e)'
                  OnEnd='e =&gt; Log("end", e)'
                  OnAdd='e =&gt; Log("add", e)'
                  OnRemove='e =&gt; Log("remove", e)'
                  OnUpdate='e =&gt; Log("update", e)'&gt;
            &lt;ItemTemplate Context="item"&gt;@@item&lt;/ItemTemplate&gt;
        &lt;/BlazorSortable&gt;
    &lt;/div&gt;
    &lt;div class="demo-col"&gt;
        &lt;BlazorSortable @@bind-Items="right" TItem="string" Group="ev"
                  Class="demo-list" ItemClass="demo-item tinted" GhostClass="demo-ghost"
                  OnAdd='e =&gt; Log("add", e)'
                  OnRemove='e =&gt; Log("remove", e)'
                  OnUpdate='e =&gt; Log("update", e)'&gt;
            &lt;ItemTemplate Context="item"&gt;@@item&lt;/ItemTemplate&gt;
        &lt;/BlazorSortable&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;div class="event-log"&gt;
    @@if (log.Count == 0)
    {
        &lt;div&gt;No events yet…&lt;/div&gt;
    }
    @@foreach (var line in log)
    {
        &lt;div&gt;@@line&lt;/div&gt;
    }
&lt;/div&gt;

@@code {
    private IList&lt;string&gt; left = new List&lt;string&gt; { "Item 1", "Item 2", "Item 3", "Item 4" };
    private IList&lt;string&gt; right = new List&lt;string&gt; { "Item A", "Item B" };
    private readonly List&lt;string&gt; log = new();

    private void Log(string name, BlazorSortableEventArgs&lt;string&gt; e)
    {
        log.Insert(0, $"[{name}] item='{e.Item}' {e.FromId[..6]}#{e.OldIndex} -&gt; {e.ToId[..6]}#{e.NewIndex}");
        if (log.Count &gt; 30) log.RemoveAt(log.Count - 1);
    }
}
    </CodeSnippet>
</div>

@code {
    private IList<string> left = new List<string> { "Item 1", "Item 2", "Item 3", "Item 4" };
    private IList<string> right = new List<string> { "Item A", "Item B" };
    private readonly List<string> log = new();

    private void Log(string name, BlazorSortableEventArgs<string> e)
    {
        log.Insert(0, $"[{name}] item='{e.Item}' {e.FromId[..6]}#{e.OldIndex} -> {e.ToId[..6]}#{e.NewIndex}");
        if (log.Count > 30) log.RemoveAt(log.Count - 1);
    }
}
