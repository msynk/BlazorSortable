@page "/cloning"

<PageTitle>BlazorSortable — Cloning</PageTitle>

<div class="demo-section">
    <h1>Cloning</h1>
    <p class="demo-lead">
        Drag from the Source list to the Target. With <code>Pull="BlazorSortablePull.Clone"</code>
        the item is copied into the Target and the original stays in the Source — so the
        same item can be cloned again and again.
    </p>

    <div class="demo-columns">
        <div class="demo-col">
            <div class="demo-col-title">Source (clone)</div>
            <BlazorSortable @bind-Items="left" TItem="CloneDemoItem" Group="clone-shared"
                      Pull="BlazorSortablePull.Clone" Clone="Duplicate"
                      Class="demo-list" ItemClass="demo-item" GhostClass="demo-ghost">
                <ItemTemplate Context="item">@item.Name</ItemTemplate>
            </BlazorSortable>
        </div>
        <div class="demo-col">
            <div class="demo-col-title">Target</div>
            <BlazorSortable @bind-Items="right" TItem="CloneDemoItem" Group="clone-shared"
                      Class="demo-list" ItemClass="demo-item tinted" GhostClass="demo-ghost">
                <ItemTemplate Context="item">@item.Name</ItemTemplate>
            </BlazorSortable>
        </div>
    </div>

    <p class="mt-3"><strong>Source:</strong> @string.Join(", ", left.Select(i => i.Name))</p>
    <p><strong>Target:</strong> @string.Join(", ", right.Select(i => i.Name))</p>
</div>

@code {
    private IList<CloneDemoItem> left = new List<CloneDemoItem>
    {
        new() { Name = "Apple" },
        new() { Name = "Banana" },
        new() { Name = "Cherry" },
        new() { Name = "Date" },
        new() { Name = "Elderberry" },
    };

    private IList<CloneDemoItem> right = new List<CloneDemoItem>
    {
        new() { Name = "Item 1" },
        new() { Name = "Item 2" },
        new() { Name = "Item 3" },
        new() { Name = "Item 4" },
        new() { Name = "Item 5" },
        new() { Name = "Item 6" },
    };

    // Produce a distinct object for every clone so each has a unique @key.
    private CloneDemoItem Duplicate(CloneDemoItem item) => new() { Name = item.Name };

    // Reference type: default (reference) equality keeps every clone's @key unique.
    public sealed class CloneDemoItem
    {
        public required string Name { get; init; }
    }
}
